.page {
  padding: 16px;
}

.header {
  display: flex;
  gap: 12px;
  align-items: center;
  margin-bottom: 16px;
}

.collect-btn {
  margin-left: auto;
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collect-btn.collected   { background: #4caf50; }
.collect-btn.uncollected { background: #bbb; }

.collect-check {
  color: #fff;
  font-size: 24px;
  font-weight: 700;
  line-height: 1;
}

.hero {
  width: 90px;
  height: 90px;
  border-radius: 12px;
  background: #f3efe8;
}

.title {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.name {
  font-size: 22px;
  font-weight: 700;
}

.meta {
  font-size: 12px;
  color: #6a6258;
}

.section {
  margin-top: 16px;
}

.section-title {
  display: block;
  font-weight: 700;
  margin-bottom: 8px;
}

.chip {
  display: inline-block;
  padding: 6px 10px;
  border-radius: 20px;
  background: #fff;
  border: 1px solid #e6dccf;
  margin: 4px 6px 4px 0;
  font-size: 12px;
}

.text {
  display: block;
  color: #3f372e;
}

.hab-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
}

.hab-card {
  display: flex;
  gap: 10px;
  align-items: center;
  background: #fff;
  border: 1px solid #e6dccf;
  border-radius: 12px;
  padding: 10px;
}

.hab-thumb {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: #f3efe8;
}

.hab-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.hab-name {
  font-weight: 700;
}

.hab-meta {
  font-size: 12px;
  color: #6a6258;
}

.req-items {
  margin-top: 8px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.req-card {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  border: 1px solid #e6dccf;
  border-radius: 10px;
  padding: 8px;
}

.req-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: #f3efe8;
  flex-shrink: 0;
}

.req-icon-placeholder {
  background: #f3efe8;
}

.req-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.req-name {
  font-size: 12px;
}

.req-qty {
  font-size: 12px;
  color: #6a6258;
}

.env-conditions {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 10px;
}

.env-chip {
  display: inline-flex;
  align-items: center;
  padding: 5px 10px;
  border-radius: 20px;
  background: #e8f4f0;
  border: 1px solid #a8d5c5;
  font-size: 12px;
  color: #2e6e56;
}

.env-qty {
  color: #2e6e56;
  font-size: 12px;
}

.req-card-tap {
  position: relative;
}

.req-arrow {
  margin-left: auto;
  color: #b0a090;
  font-size: 18px;
  line-height: 1;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.section-header .section-title {
  margin-bottom: 0;
}

.craft-yield {
  font-size: 12px;
  color: #c0392b;
  font-weight: 600;
}

.source-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.source-item {
  display: flex;
  align-items: flex-start;
  gap: 6px;
}

.source-dot {
  color: #c0392b;
  font-weight: 700;
  flex-shrink: 0;
  line-height: 1.5;
}

.source-text {
  color: #3f372e;
  line-height: 1.5;
  flex: 1;
}

.attract-collect {
  margin-left: auto;
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.attract-collect.collected   { background: #4caf50; }
.attract-collect.uncollected { background: #bbb; }

.town-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border: 1px solid #e6dccf;
  border-radius: 10px;
  padding: 10px 14px;
}

.town-value {
  font-size: 14px;
  color: #3f372e;
}

.town-placeholder {
  font-size: 14px;
  color: #b0a090;
}

.town-arrow {
  font-size: 12px;
  color: #b0a090;
}
