/* ================================================================
   图鉴外壳布局
   背景图: pokedex_bg2.png  740 × 1395px（无透明区域）
   搜索框白条: y 187~238  →  13.4% ~ 17.1%
   内容灰色区: y 281~1353  →  top 20.1%  bottom 3.0%
   内容左右边距: x 49/740=6.6%  (740-655)/740=11.5%
   ================================================================ */

page {
  height: 100%;
  background: #19143a;
}

/* 根容器：相对定位，高度 = 图片宽高比 1395/740 */
.dex-root {
  position: relative;
  width: 100%;
  padding-top: 188.5%;
  overflow: hidden;
}

/* ① 背景图：铺满根容器 */
.dex-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ② 搜索层 —— 叠在搜索框白条上（右半区）*/
.search-layer {
  position: absolute;
  top: 13.4%;
  left: 54.2%;
  right: 11.1%;
  height: 3.7%;
  display: flex;
  align-items: center;
}

.search-box {
  display: flex;
  align-items: center;
  background: transparent;
  width: 100%;
  height: 100%;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 100%;
  line-height: 1;
}

.search-placeholder {
  color: #aaa;
  font-size: 26rpx;
}

/* ③ 内容层 —— 叠在灰色内容区 */
.content-layer {
  position: absolute;
  top: 20.1%;
  left: 6.6%;
  right: 11.1%;
  bottom: 3.0%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── 第一行：类型筛选 ── */
.filter-row {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 12rpx 0 8rpx;
  flex-shrink: 0;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid #ccc;
  background: #fff;
  font-size: 24rpx;
  color: #555;
  margin-right: 10rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-chip.active {
  background: #6dcfb0;
  border-color: #6dcfb0;
  color: #fff;
  font-weight: 700;
}

/* ── 第二行：收集状态筛选 ── */
.collection-row {
  display: flex;
  flex-direction: row;
  padding: 4rpx 0 10rpx;
  flex-shrink: 0;
  gap: 10rpx;
}

.coll-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 22rpx;
  border-radius: 30rpx;
  border: 1rpx solid #ccc;
  background: #fff;
  font-size: 24rpx;
  color: #555;
  flex-shrink: 0;
}

.coll-chip.coll-active {
  background: #6dcfb0;
  border-color: #6dcfb0;
  color: #fff;
  font-weight: 700;
}

/* ── 结果滚动区 ── */
.result-scroll {
  flex: 1;
  overflow: hidden;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #888;
  padding: 6rpx 0 4rpx;
}

/* ── 卡片 ── */
.card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 18rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

/* 缩略图容器 —— 不同类型背景色 */
.thumb-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.thumb-pokemon  { background: #d4eedc; }
.thumb-habitat  { background: #c8dff5; }
.thumb-item     { background: #f5e9c8; }
.thumb-building { background: #e8d5f5; }

.thumb {
  width: 100%;
  height: 100%;
}

/* 卡片文字区 */
.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片右侧：类型图标 + 收集按钮 */
.card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.type-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.7;
}

/* 收集按钮 */
.collect-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collect-btn.collected   { background: #4caf50; }
.collect-btn.uncollected { background: #bbb; }

.collect-check {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #aaa;
  font-size: 26rpx;
}

/* ── 底部统计栏 ── */
.stats-bar {
  flex-shrink: 0;
  padding: 10rpx 0 6rpx;
  border-top: 1rpx solid #e0e0e0;
}

.stats-text {
  display: flex;
  flex-direction: row;
  justify-content: center;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 6rpx;
}

.stats-divider {
  color: #ccc;
  margin: 0 8rpx;
}

.progress-track {
  width: 92%;
  margin: 0 auto;
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.3s;
}

.progress-pokemon {
  background: linear-gradient(90deg, #6dcfb0, #4caf50);
}
